{
  "name": "branchwater",
  "version": "0.1.0",
  "description": "git for your local databases — an engine-agnostic CLI to snapshot, branch, and restore your local development databases.",
  "license": "MIT",
  "author": "Naman Chopra",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/namanchopra/branchwater.git"
  },
  "homepage": "https://github.com/namanchopra/branchwater#readme",
  "bugs": {
    "url": "https://github.com/namanchopra/branchwater/issues"
  },
  "keywords": [
    "database",
    "postgres",
    "snapshot",
    "branch",
    "version-control",
    "cli",
    "developer-tools",
    "local-development"
  ],
  "bin": {
    "bw": "dist/cli/index.js"
  },
  "main": "dist/cli/index.js",
  "types": "dist/cli/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "web"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/build-web.mjs",
    "build:server": "tsc -p tsconfig.build.json",
    "build:web": "node scripts/build-web.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "jest",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.7.4",
    "eslint": "^9.11.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0"
  }
}
